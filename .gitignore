# Variáveis de ambiente (não subir para o git)
.env

# Ambiente virtual Python
venv/
.venv/

# Cache do Python
__pycache__/
*.py[cod]
*.pyo

# Pastas geradas pelo fluxo do projeto
assets/
temp/
output/
output_tiktok/

# Logs de execução
logs/
*.log

# Histórico de vídeos processados (estado de runtime)
historico_videos.json

# Binários do FFmpeg (não versionar executáveis grandes)
bin/

# Modelos do Whisper baixados pelo faster-whisper
models/

# Credenciais OAuth do YouTube (não versionar)
client_secrets.json
token.json

# Cookies de sessão (não versionar)
tiktok_cookies.json
youtube_cookies.txt

# macOS metadata
.DS_Store
 
# macOS launchd
*.plist