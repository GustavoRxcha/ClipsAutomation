# ============================================================
# ClipsAutomation — Variáveis de Configuração
# Copie este arquivo para .env e ajuste os valores.
# ============================================================

# Modelo do Whisper para transcrição.
# Opções (do mais rápido/leve para o mais lento/preciso):
#   tiny | base | small | medium | large | large-v2 | large-v3
WHISPER_MODEL=small

# Duração-alvo de cada clipe gerado (em segundos).
# O editor agrupa frases até atingir este valor.
DURACAO_ALVO_SEGUNDOS=90

# Duração mínima para um clipe ser aceito (em segundos).
# Fragmentos menores que isso são descartados.
DURACAO_MINIMA_SEGUNDOS=45

# Privacidade dos vídeos enviados ao YouTube Shorts.
# Opções: public | unlisted | private
YOUTUBE_PRIVACY=private
