# ============================================================
# ClipsAutomation — Variáveis de Configuração
# Copie este arquivo para .env e ajuste os valores.
# ============================================================

# Modelo do Whisper para transcrição.
# Opções (do mais rápido/leve para o mais lento/preciso):
#   tiny | base | small | medium | large | large-v2 | large-v3
WHISPER_MODEL=small

# Duração-alvo de cada clipe gerado (em segundos).
# O editor agrupa frases até atingir este valor.
DURACAO_ALVO_SEGUNDOS=90

# Duração mínima para um clipe ser aceito (em segundos).
# Fragmentos menores que isso são descartados.
DURACAO_MINIMA_SEGUNDOS=45

# ------------------------------------------------------------
# YouTube
# ------------------------------------------------------------

# Chave de API pública do YouTube Data API v3 (sem OAuth).
# Obtenha em: console.cloud.google.com → APIs & Services → Credentials
# Necessária para as opções de busca automática (opções 1 e 3 do menu).
YOUTUBE_API_KEY=

# Canal do YouTube para busca automática do vídeo mais viral (opção 3).
# Aceita: channel ID (UCxxxxxx), @handle ou URL completa do canal.
# Se não configurado, o programa pedirá o canal via input na execução.
YOUTUBE_CHANNEL_ID=

# Quantos vídeos recentes do canal analisar para escolher o mais viral.
YOUTUBE_CANAL_MAX_VIDEOS=20

# Privacidade dos vídeos enviados ao YouTube Shorts.
# Opções: public | unlisted | private
YOUTUBE_PRIVACY=private

# Caminho absoluto para arquivo de cookies do YouTube no formato Netscape (opcional).
# Necessário se o download falhar com "detected as bot" em VPS.
# Como exportar: instale a extensão "Get cookies.txt LOCALLY" no Chrome,
# acesse youtube.com logado, exporte e salve no servidor.
YOUTUBE_COOKIES_FILE=


# ------------------------------------------------------------
# TikTok
# ------------------------------------------------------------

# Sessionid da conta TikTok.
# Dura 60-90 dias. Quando expirar, execute: python tiktok_setup.py
#
# Como obter:
#   Opção A (recomendado): python tiktok_setup.py auto
#     → abre Chrome, você faz login, sessionid é extraído automaticamente
#
#   Opção B (manual):
#     1. Acesse tiktok.com no seu browser e faça login
#     2. F12 → Application → Cookies → tiktok.com → sessionid → copie o valor
#     3. Cole abaixo
TIKTOK_SESSION_ID=